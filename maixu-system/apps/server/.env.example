PORT=3000
APP_NAME=maixu-server
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maixu?schema=public"
REDIS_URL="redis://127.0.0.1:6379"
JWT_SECRET="change_me"
JWT_EXPIRES_IN="7d"

# 自动超时报备检查
NOTIFICATION_TIMEOUT_CRON_ENABLED="true"
# 每 N 分钟执行一次（基于每分钟 tick）
NOTIFICATION_TIMEOUT_EVERY_MINUTES="1"
