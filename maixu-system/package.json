{
  "name": "maixu-system",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/server",
    "packages/*"
  ],
  "scripts": {
    "dev:server": "npm --workspace @maixu/server run start:dev",
    "build:server": "npm --workspace @maixu/server run build",
    "build:sdk": "npm --workspace @maixu/frontend-sdk run build",
    "prisma:generate": "npm --workspace @maixu/server run prisma:generate",
    "prisma:migrate": "npm --workspace @maixu/server run prisma:migrate",
    "prisma:seed": "npm --workspace @maixu/server run prisma:seed",
    "prisma:deploy": "npm --workspace @maixu/server run prisma:deploy"
  }
}
