{
  "name": "maixu-system",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:server": "npm --workspace @maixu/server run start:dev",
    "build:server": "npm --workspace @maixu/server run build",
    "dev:client:h5": "npm --workspace @maixu/client run dev:h5",
    "dev:client:weapp": "npm --workspace @maixu/client run dev:weapp",
    "build:client:h5": "npm --workspace @maixu/client run build:h5",
    "build:client:weapp": "npm --workspace @maixu/client run build:weapp",
    "build:sdk": "npm --workspace @maixu/frontend-sdk run build",
    "db:up": "./scripts/db-up.sh",
    "db:down": "./scripts/db-down.sh",
    "db:logs": "./scripts/db-logs.sh",
    "prisma:generate": "npm --workspace @maixu/server run prisma:generate",
    "prisma:migrate": "npm --workspace @maixu/server run prisma:migrate",
    "prisma:seed": "npm --workspace @maixu/server run prisma:seed",
    "prisma:deploy": "npm --workspace @maixu/server run prisma:deploy",
    "smoke:db": "node scripts/smoke-db-flow.mjs"
  }
}
