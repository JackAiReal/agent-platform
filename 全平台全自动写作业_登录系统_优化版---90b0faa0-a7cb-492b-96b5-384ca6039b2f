function threadRunOne3(callback, one) {
    let res = ""
    while (1) {
        try {
            let threada = threads.start(function () {
                res = callback(one)
            }).join()
            if (res) {
                console.log("获取到数据" + res)
                return res
            }
        } catch (error) {
            console.log("报错了")
            console.log(error)
            toastLog("获取超时，正在重试...")
            sleep(3000)
            continue
        }
    }
    return res
}

